{
  "name": "vecher-seans-server",
  "version": "1.0.0",
  "description": "Вечерний сеанс — backend",
  "main": "server.js",
  "scripts": {
    "dev": "node --watch server.js",
    "start": "npx prisma generate && npx prisma db push --accept-data-loss && node server.js",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "setup": "npm install && npx prisma generate && npx prisma db push"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
